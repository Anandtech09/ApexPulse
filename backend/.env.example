# ── Server ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Yahoo Finance ────────────────────────────────────────────────────
# yahoo-finance2 is an unofficial library — no API key needed.
# These values control how the library behaves.
YAHOO_FINANCE_TIMEOUT=10000
YAHOO_FINANCE_LANG=en-US
YAHOO_FINANCE_REGION=IN

# ── Google Finance (scraper settings) ───────────────────────────────
# No API key needed — we scrape public Google Finance pages.
# These control the HTTP request behaviour.
GOOGLE_FINANCE_TIMEOUT=10000
GOOGLE_FINANCE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
GOOGLE_FINANCE_ACCEPT_LANGUAGE=en-US,en;q=0.9
GOOGLE_FINANCE_BASE_URL=https://www.google.com/finance/quote

# ── Cache TTLs (milliseconds) ────────────────────────────────────────
CACHE_TTL_PRICES=60000
CACHE_TTL_FUNDAMENTALS=3600000

# ── Rate Limiting ─────────────────────────────────────────────────────
# Max number of Google Finance requests fired in parallel per batch
GOOGLE_FINANCE_CONCURRENCY=5
